rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Unified security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Hardened rules for the Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() <= 200;
        
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email; // email is immutable after creation
        
      allow delete: if isOwner(userId);
    }
  }
}
